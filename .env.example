# TTS Announcement System Configuration

# Language Configuration (en, bn, fr, jp)
TTS_LANGUAGE=en

# Voice Settings
VOICE_GENDER=female
VOICE_RATE=1.0
VOICE_PITCH=1.0
VOICE_VOLUME=1.0

# Notification Sound (true/false)
ENABLE_NOTIFICATION_SOUND=true

# Queue Settings
ANNOUNCEMENT_DELAY=2000
AUTO_CLEAR_DISPLAY=true
DISPLAY_DURATION=10000

# Debug Mode (true/false)
DEBUG_MODE=false
